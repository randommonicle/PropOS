# PropOS frontend environment.
# Copy to .env.local (gitignored) for local dev. The smoke runner reads the
# same values via app/tests/smoke/_env.ts (Tier-1 hardening: no fallback).

# Frontend Supabase connection.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_anon_key_here

# Edge Function secrets (set via `supabase secrets set` — NOT in this file).
# Listed here for documentation only; the frontend never reads them.
#
#   ANTHROPIC_API_KEY            — required by `document_processing` Edge Function (spec §5.7).
#   ANTHROPIC_RUNTIME_MODEL      — defaults to `claude-sonnet-4-6`. Override only for testing.
#   RESEND_API_KEY               — required by `dispatch-engine`.
#   APP_URL                      — required by `contractor-response` (302 redirect target).
#   DAILY_AI_COST_CAP_GBP        — FORWARD: PROD-GATE — per-firm AI spend cap (Phase 5+).
